PORT=5000
NODE_ENV=production

DB_HOST=your_mysql_host
DB_PORT=3306
DB_USER=your_mysql_user
DB_PASSWORD=your_mysql_password
DB_NAME=civicpulse

JWT_SECRET=your_jwt_secret_key
JWT_EXPIRES_IN=7d

